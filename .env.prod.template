# Copy this file to .env.prod on the VM and fill in every value.
# .env.prod is gitignored and must never be committed.

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_strong_password

# ── JWT (must be identical across all 5 services) ──────────────────────────────
# Generate: openssl rand -base64 32
JWT_SIGNING_KEY=CHANGE_ME

# ── TOTP encryption key (same format as JWT key) ──────────────────────────────
TOTP_ENCRYPTION_KEY=CHANGE_ME

# ── Super Admin seed credentials ───────────────────────────────────────────────
SUPER_ADMIN_EMAIL=shubh610@gmail.com
SUPER_ADMIN_PASSWORD=CHANGE_ME

# ── Stripe ─────────────────────────────────────────────────────────────────────
# Secret key (sk_live_...): used by backend for PaymentIntents, Checkout, etc.
STRIPE_SECRET_KEY=CHANGE_ME

# Publishable key (pk_live_...): baked into the frontend bundle at build time.
STRIPE_PUBLISHABLE_KEY=CHANGE_ME

# Webhook signing secret (whsec_...): obtained from Stripe Dashboard after
# registering https://singhrentalhub.com/api/webhooks/stripe as an endpoint.
STRIPE_WEBHOOK_SECRET=CHANGE_ME

# ── Azure Blob Storage ─────────────────────────────────────────────────────────
# Full connection string from Storage Account → Access Keys in Azure Portal.
AZURE_BLOB_CONNECTION_STRING=CHANGE_ME

# ── Azure Communication Services ───────────────────────────────────────────────
# Full connection string from ACS resource → Keys in Azure Portal.
AZURE_ACS_CONNECTION_STRING=CHANGE_ME
