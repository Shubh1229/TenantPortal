# Copy this file to .env.prod on the VM and fill in every value.
# .env.prod is gitignored and must never be committed.

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_strong_password

# ── Azure Service Principal (used to authenticate to Key Vault) ────────────────
# Create a service principal: az ad sp create-for-rbac --name tenantportal
# Grant it Key Vault Secrets User role on your vault.
AZURE_CLIENT_ID=CHANGE_ME
AZURE_CLIENT_SECRET=CHANGE_ME
AZURE_TENANT_ID=CHANGE_ME

# ── JWT (must be identical across all 5 services) ──────────────────────────────
# Generate: openssl rand -base64 32
JWT_SIGNING_KEY=CHANGE_ME

# ── TOTP encryption key (base64-encoded 32-byte AES-256-GCM key) ───────────────
# Generate: openssl rand -base64 32
TOTP_ENCRYPTION_KEY=CHANGE_ME

# ── Super Admin seed credentials ───────────────────────────────────────────────
SUPER_ADMIN_EMAIL=CHANGE_ME
SUPER_ADMIN_PASSWORD=CHANGE_ME

# ── Stripe (frontend publishable key — baked in at build time) ─────────────────
# All other Stripe secrets (secret key, webhook secrets) live in Key Vault.
STRIPE_PUBLISHABLE_KEY=CHANGE_ME
